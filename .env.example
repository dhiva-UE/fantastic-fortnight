# Runtime environment
APP_ENV=development

# Choose one:
# DB_BACKEND=sqlite
DB_BACKEND=postgres

# PostgreSQL settings
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=inbound_inventory
DB_USER=inventory_user
DB_PASSWORD=change_me

# API security
# Comma-separated list, for example:
# CORS_ORIGINS=https://inventory.example.com,https://admin.example.com
CORS_ORIGINS=
AUTH_SECRET_KEY=change_me
AUTH_TOKEN_TTL_MINUTES=480
MAX_UPLOAD_BYTES=5242880

# Optional shared folders for uploaded files
PRODUCT_IMAGES_DIR=
PURCHASE_INVOICES_DIR=
